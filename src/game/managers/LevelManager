import pygame

from levels import Level


class LevelManager:
    def __init__(self, level_names: list[str]):
        self.level_names = level_names
        self.current_index = 0
        self.current_level: Level | None = None

        self.load_level(self.current_index)

    def load_level(self, index: int) -> None:
        if index < 0 or index >= len(self.level_names):
            raise IndexError("Level index out of range")

        self.current_index = index
        level_name = self.level_names[index]

        print(f"[LevelManager] Loading level: {level_name}")
        self.current_level = Level(level_name)

    def next_level(self) -> None:
        next_index = self.current_index + 1

        if next_index >= len(self.level_names):
            next_index = 0  # loop tilbake (kan endres senere)

        self.load_level(next_index)

    def restart_level(self) -> None:
        self.load_level(self.current_index)

    def get_level(self) -> Level:
        if self.current_level is None:
            raise RuntimeError("No level loaded")
        return self.current_level